{
  "$schema": "https://schema.tauri.app/config/2",
  "bundle": {
    "targets": ["nsis"],
    "externalBin": [
      "binaries/flov-whisper-cpu",
      "binaries/flov-whisper-vulkan"
    ],
    "resources": [
      "binaries/runtime/*"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "compression": "lzma",
        "installerHooks": "./installer-hooks.nsh"
      }
    }
  }
}
